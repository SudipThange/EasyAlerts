DJANGO_SECRET_KEY=replace-with-your-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_LANGUAGE_CODE=en-us
DJANGO_TIME_ZONE=UTC
DJANGO_LOG_LEVEL=INFO
DJANGO_ENABLE_FILE_LOGGING=True

DJANGO_CORS_ALLOW_ALL_ORIGINS=True
DJANGO_CORS_ALLOWED_ORIGINS=
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_USE_X_FORWARDED_HOST=False
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_SECURE_HSTS_PRELOAD=False
DJANGO_SECURE_REFERRER_POLICY=same-origin
DJANGO_X_FRAME_OPTIONS=DENY

EASYALERTS_DB_BACKEND=sqlite
EASYALERTS_SQLITE_NAME=db.sqlite3

# Optional SQL Server settings
EASYALERTS_DB_NAME=easyalerts_db
EASYALERTS_DB_HOST=localhost
EASYALERTS_DB_PORT=
EASYALERTS_DB_USER=
EASYALERTS_DB_PASSWORD=
EASYALERTS_DB_DRIVER=ODBC Driver 18 for SQL Server
EASYALERTS_DB_TRUSTED_CONNECTION=True
EASYALERTS_DB_TRUST_SERVER_CERTIFICATE=True

JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
JWT_ROTATE_REFRESH_TOKENS=True
JWT_BLACKLIST_AFTER_ROTATION=True

MLFLOW_DB_PATH=mlflow.db
MLFLOW_ARTIFACTS_DIR=mlruns
ENABLE_SYNC_AND_RETRAIN_CRON=False
SYNC_AND_RETRAIN_CRON=0 2 * * *

# Frontend
VITE_API_URL=http://localhost:8000

# Production example overrides
# DJANGO_DEBUG=False
# DJANGO_ALLOWED_HOSTS=api.example.com
# DJANGO_CORS_ALLOW_ALL_ORIGINS=False
# DJANGO_CORS_ALLOWED_ORIGINS=https://app.example.com
# DJANGO_CSRF_TRUSTED_ORIGINS=https://app.example.com
# DJANGO_ENABLE_FILE_LOGGING=False
# DJANGO_USE_X_FORWARDED_HOST=True
# DJANGO_SECURE_SSL_REDIRECT=True
# DJANGO_SESSION_COOKIE_SECURE=True
# DJANGO_CSRF_COOKIE_SECURE=True
# DJANGO_SECURE_HSTS_SECONDS=31536000
# VITE_API_URL=https://api.example.com
